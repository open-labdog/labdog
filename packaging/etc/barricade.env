# ============================================================
# Barricade Configuration
# ============================================================
# Production environment variables for Barricade deployment.
# Copy this file to /etc/barricade/barricade.env and update
# all REQUIRED variables before starting the service.

# DATABASE_URL — PostgreSQL async connection string (REQUIRED)
# Format: postgresql+asyncpg://user:password@host:port/dbname
# Default: postgresql+asyncpg://barricade:barricade@localhost:5432/barricade
DATABASE_URL=postgresql+asyncpg://barricade:CHANGE_ME@localhost:5432/barricade

# REDIS_URL — Redis connection string for Celery broker (REQUIRED)
# Format: redis://[password@]host:port/db
# Default: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# SECRET_KEY — JWT signing key for authentication (REQUIRED — MUST CHANGE)
# Used to sign and verify JWT tokens for API authentication.
# Generate with: openssl rand -base64 32
# CRITICAL: Use a strong, random value in production. Never commit real keys.
SECRET_KEY=CHANGE_ME

# ENCRYPTION_KEY — AES-256-GCM master key for SSH key encryption (REQUIRED — MUST CHANGE)
# Used to encrypt SSH private keys at rest in the database.
# Must be exactly 32 bytes, base64-encoded.
# Generate with: openssl rand -base64 32
# CRITICAL: Use a strong, random value in production. Never commit real keys.
ENCRYPTION_KEY=CHANGE_ME

# BARRICADE_SERVER_IP — IP address of the Barricade server (REQUIRED)
# Used in the auto-injected SSH lockout prevention rule to ensure
# the Barricade server itself is never accidentally blocked.
# Set to the IP address of the interface where Barricade runs.
BARRICADE_SERVER_IP=127.0.0.1

# ALLOWED_ORIGINS — CORS allowed origins (OPTIONAL)
# Comma-separated list of origins allowed to make requests to the API.
# Default: http://localhost:3000
# Example: https://barricade.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:3000

# NEXT_PUBLIC_API_URL — Backend API URL for frontend (REQUIRED)
# The URL the frontend uses to proxy API requests to the backend.
# Must be accessible from the browser/client.
# Example: http://localhost:8000 (development)
# Example: https://api.barricade.example.com (production)
NEXT_PUBLIC_API_URL=http://localhost:8000

# DRIFT_CHECK_INTERVAL_MINUTES — Automatic drift detection interval (OPTIONAL)
# How often (in minutes) to automatically check for configuration drift
# on managed hosts. Set to 0 to disable automatic checks.
# Default: 30
DRIFT_CHECK_INTERVAL_MINUTES=30
