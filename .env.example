# Barricade Docker Compose environment variables
# Copy this file into the dev directory and update values for your environment:
#   cp .env.example dev/.env

# --- Postgres ---
POSTGRES_PASSWORD=barricade

# --- Security ---
# Must be 32 bytes, standard base64-encoded.
# Generate with: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# (dev.sh auto-seeds these on first run)
BARRICADE_SECURITY__SECRET_KEY=CHANGE_ME
BARRICADE_SECURITY__ENCRYPTION_KEY=CHANGE_ME

# IP address that Barricade uses to reach managed hosts (for SSH lockout rule)
BARRICADE_SECURITY__BARRICADE_SERVER_IP=127.0.0.1

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
