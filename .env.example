# Legacy .env — Barricade now uses barricade.toml for configuration.
# See barricade.toml in the project root (development) or
# /etc/barricade/barricade.toml (production).
#
# The only env vars still used:
#   BARRICADE_CONFIG  — path to barricade.toml (optional, auto-detected)
#   POSTGRES_PASSWORD — used by docker-compose for the postgres container
#   NEXT_PUBLIC_API_URL — used by the frontend container

POSTGRES_PASSWORD=barricade
NEXT_PUBLIC_API_URL=http://localhost:8000
