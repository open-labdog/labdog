# =============================================================================
# LabDog — Environment Variables Reference
# =============================================================================
# All settings can be provided as environment variables using the pattern:
#   LABDOG_<SECTION>__<KEY>=value
#
# To use: copy this file and fill in the required values.
#   cp .env.example dev/.env
#
# Settings can also be defined in dev/labdog.toml. Environment variables
# always override the TOML file.
#
# NOTE: Operational settings (log level, drift interval, SSH/Ansible timeouts,
# discovery tuning, audit retention) are managed via the Settings page in the
# UI and stored in the database — they do not belong here.
# =============================================================================


# =============================================================================
# REQUIRED — LabDog refuses to start without these
# =============================================================================

# JWT signing key used to sign session tokens.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(64))"
LABDOG_SECURITY__SECRET_KEY=CHANGE_ME

# AES-256-GCM key for encrypting stored SSH private keys. Must be 32 bytes,
# standard base64-encoded.
# Generate with: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
LABDOG_SECURITY__ENCRYPTION_KEY=CHANGE_ME


# =============================================================================
# DATABASE
# =============================================================================

# PostgreSQL connection string.
LABDOG_DATABASE__URL=postgresql+asyncpg://labdog:labdog@localhost:5432/labdog

# Connection pool tuning (optional).
# LABDOG_DATABASE__POOL_SIZE=5
# LABDOG_DATABASE__MAX_OVERFLOW=10
# LABDOG_DATABASE__POOL_TIMEOUT=30


# =============================================================================
# REDIS
# =============================================================================

# Redis URL used by Celery workers and the RedBeat scheduler.
LABDOG_REDIS__URL=redis://localhost:6379/0


# =============================================================================
# SECURITY
# =============================================================================

# IP address LabDog itself uses to reach managed hosts over SSH.
# Used to prevent LabDog from locking itself out when generating firewall
# rules. Set to the host's LAN IP (not 127.0.0.1) in real deployments.
# LABDOG_SECURITY__LABDOG_SERVER_IP=192.168.1.10

# Allowed CORS origins — only needed when the frontend is served from a
# different origin than the API (e.g. local Next.js dev server).
# LABDOG_SECURITY__ALLOWED_ORIGINS=http://localhost:3000

# Mark session cookies as Secure. Set to true when serving over HTTPS.
# LABDOG_SECURITY__COOKIE_SECURE=true

# Cookie domain — set when the frontend and API are on different subdomains.
# LABDOG_SECURITY__COOKIE_DOMAIN=.example.com

# Session lifetime in seconds. Default is 24 hours.
# LABDOG_SECURITY__SESSION_LIFETIME_SECONDS=86400


# =============================================================================
# SERVER
# =============================================================================

# Bind address and port.
# LABDOG_SERVER__HOST=0.0.0.0
# LABDOG_SERVER__PORT=8000

# Absolute path to the compiled Next.js static export. Auto-detected when empty.
# LABDOG_SERVER__STATIC_DIR=/usr/lib/labdog/frontend

# IP(s) allowed to set X-Forwarded-For (space-separated). Set to your reverse
# proxy IP when running behind nginx/Caddy/Traefik.
# LABDOG_SERVER__FORWARDED_ALLOW_IPS=10.0.0.1


# =============================================================================
# TLS — only if terminating TLS at the app rather than a reverse proxy
# =============================================================================

# LABDOG_TLS__CERT_FILE=/etc/labdog/tls/fullchain.pem
# LABDOG_TLS__KEY_FILE=/etc/labdog/tls/privkey.pem
# LABDOG_TLS__FORCE_HTTPS=true


# =============================================================================
# RATE LIMITING
# =============================================================================

# LABDOG_RATE_LIMIT__ENABLED=true
# LABDOG_RATE_LIMIT__LOGIN=5/minute
# LABDOG_RATE_LIMIT__API=100/minute


# =============================================================================
# LOGGING
# =============================================================================

# Structured JSON logging for log aggregators (e.g. Loki, Datadog).
# Log level and audit retention are configured in the UI Settings page.
# LABDOG_LOGGING__FORMAT=json


# =============================================================================
# SSH WEB TERMINAL
# =============================================================================

# Max concurrent terminal sessions (not SSH sync connections).
# LABDOG_SSH__MAX_SESSIONS_PER_USER=5
# LABDOG_SSH__MAX_TOTAL_SESSIONS=50
# LABDOG_SSH__DEFAULT_PORT=22


# =============================================================================
# CELERY WORKERS
# =============================================================================

# Number of worker processes for running sync, drift, and discovery tasks.
# LABDOG_CELERY__CONCURRENCY=4

# Recycle a worker process after this many tasks (prevents memory leaks).
# LABDOG_CELERY__MAX_TASKS_PER_CHILD=100


# =============================================================================
# DISCOVERY
# =============================================================================

# Smallest prefix length allowed for scan CIDRs — prevents accidental sweeps
# of huge ranges. /20 = max 4094 addresses per scan.
# LABDOG_DISCOVERY__MIN_PREFIX=20

# Max hosts that can be bulk-added in a single operation.
# LABDOG_DISCOVERY__MAX_BULK_ADD=50


# =============================================================================
# DOCKER COMPOSE — used by dev/docker-compose.yml only
# =============================================================================

# Password for the local PostgreSQL container.
POSTGRES_PASSWORD=labdog
